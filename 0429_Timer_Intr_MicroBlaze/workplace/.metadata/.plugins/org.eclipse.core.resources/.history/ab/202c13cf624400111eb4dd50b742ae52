#include "LED.h"
#include "../../HAL/GPIO/GPIO.h"
#include "../../common/common.h"

#define LED_PORT GPIOC

#define LED_PIN_0 GPIO_PIN_0
#define LED_PIN_1 GPIO_PIN_1
#define LED_PIN_2 GPIO_PIN_2
#define LED_PIN_3 GPIO_PIN_3
#define LED_PIN_4 GPIO_PIN_4
#define LED_PIN_5 GPIO_PIN_5
#define LED_PIN_6 GPIO_PIN_6
#define LED_PIN_7 GPIO_PIN_7

#define ON 0
#define OFF 1

typedef enum {
	round1, round2, round3, round4
} round_stat_t;

round_stat_t round_state = round1;

void LED_Init() {
	GPIO_SetMode(LED_PORT,
			LED_PIN_0 | LED_PIN_1 | LED_PIN_2 | LED_PIN_3 | LED_PIN_4
					| LED_PIN_5 | LED_PIN_6 | LED_PIN_7, OUTPUT);
}

void LED_SetPort(GPIO_Typedef_t *LED_Port, uint32_t LED_Pin, int OnOff) {
	GPIO_WritePin(LED_Port, LED_Pin, OnOff);
}

void LED_CountClock_Mode() {
	LED_SetPort(LED_PORT, LED_PIN_0, ON);
	LED_SetPort(LED_PORT, LED_PIN_1, ON);
}

void LED_Clock_FND_Mode() {
	LED_SetPort(LED_PORT, LED_PIN_2, ON);
	LED_SetPort(LED_PORT, LED_PIN_3, ON);
}

int LED_Delay() {
	static uint32_t prevTime = 0;
	if (millis() - prevTime <= 100 - 1) {
		return 1;
	}
	prevTime = millis();
}
void LED_Round_UpCounter() {
	switch (round_state) {
	case round1:
		LED_SetPort(LED_PORT, LED_PIN_4, ON);
		if (LED_Delay() == 1) {
			LED_SetPort(LED_PORT, LED_PIN_4, OFF);
			round_state = round2;
		}
		break;
	case round2:
		LED_SetPort(LED_PORT, LED_PIN_5, ON);
		if (LED_Delay() == 1) {
			LED_SetPort(LED_PORT, LED_PIN_5, OFF);
			round_state = round3;
		}
		break;
	case round3:
		LED_SetPort(LED_PORT, LED_PIN_6, ON);
		if (LED_Delay() == 1) {
			LED_SetPort(LED_PORT, LED_PIN_6, OFF);
			round_state = round3;
		}
		break;
	case round4:
		LED_SetPort(LED_PORT, LED_PIN_7, ON);
		if (LED_Delay() == 1) {
			LED_SetPort(LED_PORT, LED_PIN_7, OFF);
			round_state = round3;
		}
		break;
	}
}

void LED_Round_Clock() {
	switch (round_state) {
	case round1:
		LED_SetPort(LED_PORT, LED_PIN_7, ON);
		if (LED_Delay() == 1) {
			LED_SetPort(LED_PORT, LED_PIN_7, OFF);
			round_state = round2;
		}
		break;
	case round2:
		LED_SetPort(LED_PORT, LED_PIN_6, ON);
		if (LED_Delay() == 1) {
			LED_SetPort(LED_PORT, LED_PIN_6, OFF);
			round_state = round3;
		}
		break;
	case round3:
		LED_SetPort(LED_PORT, LED_PIN_5, ON);
		if (LED_Delay() == 1) {
			LED_SetPort(LED_PORT, LED_PIN_5, OFF);
			round_state = round3;
		}
		break;
	case round4:
		LED_SetPort(LED_PORT, LED_PIN_4, ON);
		if (LED_Delay() == 1) {
			LED_SetPort(LED_PORT, LED_PIN_4, OFF);
			round_state = round3;
		}
		break;
	}
}

