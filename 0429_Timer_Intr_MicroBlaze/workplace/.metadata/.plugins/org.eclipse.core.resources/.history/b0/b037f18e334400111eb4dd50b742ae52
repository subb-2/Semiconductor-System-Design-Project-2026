#include "common.h"

uint32_t millis_tick = 0;

uint32_t millis() {
	return millis_tick;
}

//1ms 除問葆棻 1噶 隸陛
void millis_inc() {
	millis_tick++;
}

void delay_ms(uint32_t msec)
{
	//usleep(msec*1000);
	delay_us(msec*1000);
}

void delay_us(uint32_t usec)
{
	static uint32_t prevtimer = 0;
	uint32_t curtimer = TMR_GetCNT(TMR0);

	while (curtimer - prevtimer < usec);
	prevtimer = curtimer;

	//usleep(usec);
}


