#include "LED.h"
#include "../../HAL/GPIO/GPIO.h"
#include "../../common/common.h"

// LED Driver БИЧіЧЯБт

void Led_Init(hLed *hled, GPIO_Typedef_t *GPIOx, uint32_t GPIO_PIN)
{
	hled->GPIOx = GPIOx;
	hled->GPIO_Pin = GPIO_Pin;
	GPIO_SetMode(hled->GPIOx, hled->GPIO_PIN, OUTPUT);
}

void LED_On(hLed *hled) // LED 1АГ On
{
	//LEDАЁ GPIOИІ КЮИЅ АЭ
	//GPIOДТ ДЉАЁ ГЊИІ КвЗЖДТСі И№ИЇ
	//callerИИ ДЉБИИІ КЮИЃДТСі ОЫАэ РжРН
	GPIO_WritePin(hled->GPIOx, hled->GPIO_Pin, SET);
	//ЙќПыРИЗЮ ЛчПыАЁДЩЧб ЧдМі
}

void LED_Off(hLed *hled) // LED 1АГ Off
{
	GPIO_WritePin(hled->GPIOx, hled->GPIO_Pin, RESET);
}

void LED_Toggle() // LED 1АГ Toggle
{
	GPIO_TogglePin(hled->GPIOx, hled->GPIO_Pin);
}

// LED GPIOC 8АГРЧ pinАњ ПЌАсЕЧОю РжРН, GPIOC PortПЁ 8АГРЧ АЊРЛ ЕПНУПЁ Write, GPIOC ODRПЁ write
void LED_WritePort(hLed *hled, uint8_t data)
{
	GPIO_WritePort(hled->GPIOx, data);
}
// LED GPIOC 8АГРЧ pinАњ ПЌАсЕЧОю РжРН, GPIOC PortПЁ 8АГРЧ АЊРЛ ЕПНУПЁ Read, GPIOC ODR АЊ read
uint8_t LED_ReadPort(hLed *hled)
{
	return (uint8_t)GPIO_ReadPort(hled->GPIOx);
}
