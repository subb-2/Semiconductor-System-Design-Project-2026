#ifndef SRC_DRIVER_BUTTON_BUTTON_H_
#define SRC_DRIVER_BUTTON_BUTTON_H_

typedef enum {
	RELEASED = 0,
	PUSHED
}button_state_t;

typedef enum {
	NO_ACT = 0,
	ACT_RELEASED,
	ACT_PUSHED
}button_act_t;

typedef struct {
	GPIO_Typedef_t *GPIOx;
	uint32_t GPIO_Pin;
	button_state_t prevState;
}hBtn_t;

void Button_Init();
button_act_t Button_GetState(hBtn_t *hbtn);


#endif /* SRC_DRIVER_BUTTON_BUTTON_H_ */
