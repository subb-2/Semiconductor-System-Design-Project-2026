typedef struct {
	uint32_t SR;
	uint32_t TDR;
	uint32_t RDR;
	uint32_t CR;
}UART_Typedef_t;

#define UART_BASE_ADDR XPAR_UART_0_S00_AXI_BASEADDR
//uart СжМв = UART0
#define UART0 ((UART_Typedef_t *)(UART_BASE_ADDR))


uint8_t UART_IsSending(UART_Typedef_t *uart)
{
	// 0РЬИщ sending Сп
	return (uart->SR & 1U<<0) ? 0 : 1;
}

uint8_t UART_IsAvalable(UART_Typedef_t *uart)
{
	return (uart->SR & 1U<<1) ? 1 : 0;
}

void UART_SendByte(UART_Typedef_t *uart, uint8_t data)
{
	while(UART_IsSending());
	uart->TDR = data;
}

uint8_t UART_RecvByte(UART_Typedef_t *uart)
{
	uint8_t rx_data;
	while(!UART_IsAvalable());
	rx_data = uart->RDR;
	return rx_data;
}


void UART_Send(UART_Typedef_t *uart, uint8_t *pData, uint16_t len)
{
	for(int i = 0; i < len; i++) {
		UART_SendByte(uart, pData[i]);
	}
}



hBtn_t hBtnMode;

Mode_State_t curMode = WATCH;

void ap_init() {
	Button_Init(&hBtnMode, GPIOA, GPIO_PIN_5);
	Disp_Init();

	UpCounter_Init();
	TimeClock_Init();

	//РЮХЭЗДЦЎПЁ ДыЧб НУНКХл МГСЄ
	SetupInterruptSystem();
	TMR0_Init();
	TMR1_Init();
	TMR2_Init();

}

void ap_excute() {

	//UART_Send(UART0, "Hello World KCCI STC\n", strlenc("Hello World KCCI STC\n"));

	char str[] = {"Hello World KCCI STC\n"};
	uint8_t rxData;
	for (int i = 0; i<strlen(str); i++) {
		UART_SendByte(UART0, str[i]);
		rxData = UART_RecvByte(UART0);
		xil_printf("%c", rxData);
	}

	while (1) {

		switch (curMode) {
		case WATCH:
			TimeClock_Excute();
			Disp_SetMode(DISP_TIME_CLOCK);

			if (Button_GetState(&hBtnMode) == ACT_RELEASED) {
				curMode = COUNTER;
				FND_SetDP(FND_DIGIT_100, OFF);
			}

			break;

		case COUNTER:
			UpCounter_Excute();
			Disp_SetMode(DISP_UP_COUNTER);

			if (Button_GetState(&hBtnMode) == ACT_RELEASED) {
				curMode = WATCH;
			}

			break;
		}
	}
}
