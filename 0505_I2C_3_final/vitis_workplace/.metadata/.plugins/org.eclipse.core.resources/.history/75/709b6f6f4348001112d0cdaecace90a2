void I2C_Wait_Done(I2C_Typedef_t *I2Cx) {
    delay_ms(1);  // 100KHz I2C에서 1바이트 = 약 90us, 1ms면 충분
    I2Cx->COMMAND = 0x00;
}

void I2C_CMD_START(I2C_Typedef_t *I2Cx) {
	I2Cx->COMMAND = (1 << I2C_CMD_START_BIT);
	I2C_Wait_Done(I2Cx);
}

void I2C_CMD_WRITE(I2C_Typedef_t *I2Cx) {
	I2Cx->COMMAND = (1 << I2C_CMD_WRITE_BIT);
	I2C_Wait_Done(I2Cx);
}

void I2C_CMD_READ(I2C_Typedef_t *I2Cx) {
	I2Cx->COMMAND = (1 << I2C_CMD_READ_BIT);
	I2C_Wait_Done(I2Cx);
}

void I2C_CMD_STOP(I2C_Typedef_t *I2Cx) {
	I2Cx->COMMAND = (1 << I2C_CMD_STOP_BIT);
	I2C_Wait_Done(I2Cx);
}

uint8_t I2C_Write_Data(I2C_Typedef_t *I2Cx, uint8_t slave_addr, uint8_t tx_data) {
	I2C_CMD_START(I2Cx);

	I2Cx->TX_REG = (slave_addr << 1) | 0;
	I2C_CMD_WRITE(I2Cx);

	if (I2Cx->RX_STATUS & I2C_ACK_OUT_BIT) {
		I2C_CMD_STOP(I2Cx); // 대답이 없으니 통신 강제 종료
		return 1;           // 에러(1) 반환
	}

	I2Cx->TX_REG = tx_data;
	I2C_CMD_WRITE(I2Cx);

	if (I2Cx->RX_STATUS & I2C_ACK_OUT_BIT) {
		I2C_CMD_STOP(I2Cx); // 대답이 없으니 통신 강제 종료
		return 1;           // 에러(1) 반환
	}

	I2C_CMD_STOP(I2Cx);
	return 0;
}
uint8_t I2C_Read(I2C_Typedef_t *I2Cx, uint8_t ack) {
    while (I2Cx->RX_STATUS & I2C_BUSY_BIT);

    if (ack == 1) {
        I2Cx->TX_REG = I2C_CMD_READ_BIT | I2C_ACK_IN_BIT;
    } else {
        I2Cx->TX_REG = I2C_CMD_READ_BIT;
    }

    while ((I2Cx->TX_REG & I2C_DONE_BIT) == 0);

    return (uint8_t)(I2Cx->RX_STATUS);
}

