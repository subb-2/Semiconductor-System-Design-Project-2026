void I2C_ap_Read_Execute() {
    uint8_t slave_sw_data = 0;
    xil_printf("[READ] Requesting data...\r\n");

    // 1. START 전송
    I2C_CMD_START(I2C); // 여기서 멈춘다면 I2C 버스 라인(SDA/SCL)이 이미 Low로 묶여있는지 확인해야 합니다.

    // 2. 주소 전송 (Read 모드)
    I2C->TX_REG = (SLAVE_ADDR << 1) | 1;
    I2C_CMD_WRITE(I2C);

    // ★ 중요: NACK가 났는데 계속 진행하면 하드웨어가 멈출 수 있습니다.
    if (I2C->RX_STATUS & (1 << 8)) { // I2C_ACK_OUT_BIT
        xil_printf(" -> Error: Slave NACK on ADDR!\r\n");
        I2C_CMD_STOP(I2C); // 멈춤 방지를 위해 STOP을 던지고 종료
        return;
    }

    // 3. 데이터 읽기
    I2C->TX_REG = 0x00; // ACK/NACK 설정 등 (설계에 따라 다름)
    I2C_CMD_READ(I2C);

    slave_sw_data = (uint8_t)(I2C->RX_STATUS & 0xFF);
    // 단일 바이트 읽기 및 종료
    slave_sw_data = I2C_Read_Data(I2C, 1); // 1을 넣어 NACK 발생 -> 통신 종료 준비 완료
    I2C_CMD_STOP(I2C);                     // 이제 안전하게 STOP 가능!

    xil_printf(" -> Success! Received: 0x%02X\r\n", slave_sw_data);
}
