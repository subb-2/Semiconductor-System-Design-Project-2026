#define GPIO_PIN_7 0x01 //0b10000000

//why 
#define INPUT 0
#define OUTPUT 1 

#define RESET 0
#define SET 1


void GPIO_SetMode (GPIO_Typedef_t *GPIOx, uint32_t GPIO_PIN, int GPIO_Dir)
{
	if(GPIO_Dir == OUTPUT) {
		GPIOx->CR |= GPIO_PIN;
	} else {
		GPIOx->CR &= ~(GPIO_PIN);
	}
}


void GPIO_WritePin(GPIO_Typedef_t *GPIOx, uint32_t GPIO_PIN, int level)
{
	if (level == SET)
	{
		GPIOx->ODR |= GPIO_PIN;
	} else {
		GPIOx->ODR &= ~GPIO_PIN;
	}
	
}


uint32_t GPIO_ReadPin(GPIO_Typedef_t *GPIOx, uint32_t GPIO_PIN, int levle)
{
	GPIOx->ODR ^= GPIO_PIN;
}

//Toggle Pin
void GPIO_TogglePin()
{
	GPIOx->ODR ^= GPIO_PIN;
}

