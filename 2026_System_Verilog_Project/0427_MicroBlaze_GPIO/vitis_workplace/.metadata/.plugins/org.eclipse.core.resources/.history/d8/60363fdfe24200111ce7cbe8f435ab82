
#include "Time.h"


Wath_State_t w_state = {0, 0, 0, 0};


void Watch_Init()
{
    w_state.hour = 0;
    w_state.min = 0;
    w_state.sec = 0;
    w_state.msec = 0;
}

void Watch_Execute()
{
    Watch_DispLoop();
    Watch_Run();
}

void Watch_DispLoop()
{
    FND_DispDigit();
}

void Watch_Run()
{
    static uint32_t WatchCounter = 0;


    if (millis() - WatchCounter < 10) {
        return;
    }
    WatchCounter = millis();

    w_state.msec++;

    if (w_state.msec >= 100) {
        w_state.msec = 0;
        w_state.sec++;

        if (w_state.sec >= 60) {
            w_state.sec = 0;
            w_state.min++;

            if (w_satae.min >= 60) {
                w_state.min = 0;
                w_state.hour++;

                if (w_state.hour >= 24) {
                    w_state.hour = 0;
                }
            }
        }
    }


    uint16_t FNDData = (w_state.min * 100) + w_state.sec;
    FND_SetNum(FNDData);


    if (w_state.msec < 50) {
    	FND_DP_ON();
    } else {
    	FND_DP_OFF();
    }
}
