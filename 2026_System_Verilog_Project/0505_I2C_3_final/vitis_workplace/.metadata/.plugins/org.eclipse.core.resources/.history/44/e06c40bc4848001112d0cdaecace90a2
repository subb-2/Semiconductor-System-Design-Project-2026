#include "xil_printf.h"
#include "I2C.h"
#include "../../common/common.h"
// I2C.c

void I2C_Wait_Done(I2C_Typedef_t *I2Cx) {
    uint32_t timeout = 0;
    while (!(I2Cx->RX_STATUS & (1 << 10))) {
        if (++timeout > 1000000) {
            xil_printf("[ERROR] I2C Timeout!\r\n");
            break;
        }
    }
    // COMMAND ХЌИЎОю СІАХ done_realРК ДйРН 0x00 write НУ ХЌИЎОюЕЪ
}

// CMD ЧдМіЕщ: COMMAND ММЦУИИ, ХЌИЎОюДТ Wait_Done ШФ ДйРН ИэЗЩРЬ ОЫОЦМ­ Чд
void I2C_CMD_START(I2C_Typedef_t *I2Cx) {
    I2Cx->COMMAND = (1 << I2C_CMD_START_BIT);
    I2C_Wait_Done(I2Cx);
    I2Cx->COMMAND = 0x00;  // done ШЎРЮ ШФ ХЌИЎОю
    for(volatile int i=0; i<50; i++);
}

void I2C_CMD_WRITE(I2C_Typedef_t *I2Cx) {
    I2Cx->COMMAND = (1 << I2C_CMD_WRITE_BIT);
    I2C_Wait_Done(I2Cx);
    I2Cx->COMMAND = 0x00;
    for(volatile int i=0; i<50; i++);
}

void I2C_CMD_STOP(I2C_Typedef_t *I2Cx) {
    I2Cx->COMMAND = (1 << I2C_CMD_STOP_BIT);
    I2C_Wait_Done(I2Cx);
    I2Cx->COMMAND = 0x00;
    for(volatile int i=0; i<50; i++);
}

uint8_t I2C_Read_Data(I2C_Typedef_t *I2Cx, uint8_t ack) {
    // 1. ack_in МГСЄ (0x04)
    I2Cx->TX_REG = (ack == 1) ? I2C_ACK_IN_BIT : 0x00;

    // 2. cmd_read ЙпЧр (0x00)РЬ writeАЁ РЬРќ done_realРЛ ХЌИЎОюЧд
    I2Cx->COMMAND = (1 << I2C_CMD_READ_BIT);

    // 3. done_real ДыБт
    uint32_t timeout = 0;
    while (!(I2Cx->RX_STATUS & (1 << 10))) {
        if (++timeout > 1000000) {
            xil_printf("[ERROR] Read Timeout!\r\n");
            return 0xFF;
        }
    }

    // 4. done=1 ЛѓХТПЁМ­ rx_data РаБт
    uint8_t rx = (uint8_t)(I2Cx->RX_STATUS & 0xFF);

    // 5. Бз ДйРН ХЌИЎОю
    I2Cx->COMMAND = 0x00;
    for(volatile int i=0; i<50; i++);

    return rx;
}
