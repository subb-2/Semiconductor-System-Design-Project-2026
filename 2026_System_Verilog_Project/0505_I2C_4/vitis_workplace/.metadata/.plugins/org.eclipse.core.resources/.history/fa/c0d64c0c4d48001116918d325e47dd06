#include "xil_printf.h"
#include "I2C.h"

void I2C_Wait_Done(I2C_Typedef_t *I2Cx) {
    uint32_t timeout = 0;
    // busy가 1이 될 때까지 대기 (명령 시작 확인)
    while (!(I2Cx->RX_STATUS & I2C_BUSY_BIT)) {
        if (++timeout > 100000) break;
    }
    // busy가 0이 될 때까지 대기 (명령 완료 = WAIT_CMD 진입)
    timeout = 0;
    while (I2Cx->RX_STATUS & I2C_BUSY_BIT) {
        if (++timeout > 1000000) {
            xil_printf("[ERROR] Timeout!\r\n");
            break;
        }
    }
    I2Cx->COMMAND = 0x00;
    for (volatile int i = 0; i < 100; i++);
}

void I2C_CMD_START(I2C_Typedef_t *I2Cx) {
	I2Cx->COMMAND = (1 << I2C_CMD_START_BIT);
	I2C_Wait_Done(I2Cx);
}

void I2C_CMD_WRITE(I2C_Typedef_t *I2Cx) {
	I2Cx->COMMAND = (1 << I2C_CMD_WRITE_BIT);
	I2C_Wait_Done(I2Cx);
}

void I2C_CMD_READ(I2C_Typedef_t *I2Cx) {
	I2Cx->COMMAND = (1 << I2C_CMD_READ_BIT);
	I2C_Wait_Done(I2Cx);
}

void I2C_CMD_STOP(I2C_Typedef_t *I2Cx) {
	I2Cx->COMMAND = (1 << I2C_CMD_STOP_BIT);
	I2C_Wait_Done(I2Cx);
}

uint8_t I2C_Write_Data(I2C_Typedef_t *I2Cx, uint8_t slave_addr, uint8_t tx_data) {
	I2C_CMD_START(I2Cx);

	I2Cx->TX_REG = (slave_addr << 1) | 0;
	I2C_CMD_WRITE(I2Cx);

	if (I2Cx->RX_STATUS & I2C_ACK_OUT_BIT) {
		I2C_CMD_STOP(I2Cx); // 대답이 없으니 통신 강제 종료
		return 1;           // 에러(1) 반환
	}

	I2Cx->TX_REG = tx_data;
	I2C_CMD_WRITE(I2Cx);

	if (I2Cx->RX_STATUS & I2C_ACK_OUT_BIT) {
		I2C_CMD_STOP(I2Cx); // 대답이 없으니 통신 강제 종료
		return 1;           // 에러(1) 반환
	}

	I2C_CMD_STOP(I2Cx);
	return 0;
}

uint8_t I2C_Read_Data(I2C_Typedef_t *I2Cx, uint8_t ack) {
    I2Cx->TX_REG = (ack == 1) ? I2C_ACK_IN_BIT : 0x00;
    I2Cx->COMMAND = (1 << I2C_CMD_READ_BIT);

    // busy 1 대기
    uint32_t timeout = 0;
    while (!(I2Cx->RX_STATUS & I2C_BUSY_BIT)) {
        if (++timeout > 100000) break;
    }
    // busy 0 대기
    timeout = 0;
    while (I2Cx->RX_STATUS & I2C_BUSY_BIT) {
        if (++timeout > 1000000) {
            xil_printf("[ERROR] Read Timeout!\r\n");
            return 0xFF;
        }
    }

    // WAIT_CMD 상태 = busy=0, rx_data 유효
    uint8_t rx = (uint8_t)(I2Cx->RX_STATUS & 0xFF);
    I2Cx->COMMAND = 0x00;
    for (volatile int i = 0; i < 100; i++);
    return rx;
}
