void I2C_ap_Read_Execute() {
    uint8_t slave_sw_data = 0;

    I2C_CMD_START(I2C);

    I2C->TX_REG = (SLAVE_ADDR << 1) | 1;  // 0x12 << 1 | 1 = 0x25
    xil_printf("[READ] Sending addr byte: 0x%02X\r\n", (SLAVE_ADDR << 1) | 1);
    I2C_CMD_WRITE(I2C);

    // ★ 여기서 ACK_OUT 상태 직접 출력
    uint32_t status_after_addr = I2C->RX_STATUS;
    xil_printf(" -> STATUS after ADDR write: 0x%08X\r\n", status_after_addr);
    xil_printf(" -> ack_out(bit8): %d\r\n", (status_after_addr >> 8) & 1);
    xil_printf(" -> busy(bit9):    %d\r\n", (status_after_addr >> 9) & 1);
    xil_printf(" -> done(bit10):   %d\r\n", (status_after_addr >> 10) & 1);

    if (status_after_addr & I2C_ACK_OUT_BIT) {
        xil_printf(" -> Error: Slave NACK on ADDR!\r\n");
        I2C_CMD_STOP(I2C);
        return;
    }

    slave_sw_data = I2C_Read_Data(I2C, 1);
    xil_printf(" -> Final rx: 0x%02X\r\n", slave_sw_data);

    I2C_CMD_STOP(I2C);
    GPIO_WritePort(GPIOC, slave_sw_data);
}
